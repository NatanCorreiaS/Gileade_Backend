@base = https://unbitten-crescent-hut.ngrok-free.dev/api/v1

### 1) Criar pessoa (guarde o id)
POST {{base}}/pessoas
Content-Type: application/json

{
	"nome": "Comprador Teste",
	"tipo_usuario": "Usuario",
	"senha": "hash_da_senha",
	"cpf": "11111111111",
	"idade": 29,
	"celular": "+55 11 99999-0001",
	"igreja": "Igreja Central",
	"papel_igreja": "Membro",
	"estado_civil": "Solteiro(a)",
	"email": "comprador.teste@exemplo.com",
	"sexo": "Masculino",
	"cidade": "Sao Paulo",
	"estado_uf": "SP",
	"escolaridade": "Ensino Superior Completo"
}

### 2) Criar ticket Individual (guarde o id)
POST {{base}}/tickets
Content-Type: application/json

{
	"tipo": "Individual",
	"nome": "Ingresso Individual",
	"descricao": "Entrada individual",
	"preco": "120.00",
	"quantidade_disponivel": 100,
	"data_evento": "2026-10-20"
}

### 3) Criar ticket Duo (guarde o id)
POST {{base}}/tickets
Content-Type: application/json

{
	"tipo": "Duo",
	"nome": "Ingresso Duo",
	"descricao": "Entrada para duas pessoas",
	"preco": "220.00",
	"quantidade_disponivel": 50,
	"data_evento": "2026-10-20"
}

### 4) Criar ticket Caravana (guarde o id)
POST {{base}}/tickets
Content-Type: application/json

{
	"tipo": "Caravana",
	"nome": "Ingresso Caravana",
	"descricao": "Entrada para grupo",
	"preco": "900.00",
	"quantidade_disponivel": 20,
	"data_evento": "2026-10-20"
}

### 5) Checkout Individual (1 beneficiado)
POST {{base}}/pagamentos/checkout
Content-Type: application/json

{
	"usuario_id": 1,
	"ticket_id": 1,
	"quantidade": 1,
	"beneficiados": [
		{
			"nome": "Beneficiado 1",
			"cpf": "11111111111",
			"idade": 29,
			"celular": "+55 11 99999-0001",
			"igreja": "Igreja Central",
			"papel_igreja": "Membro",
			"estado_civil": "Solteiro(a)",
			"email": "beneficiado1@exemplo.com",
			"sexo": "Masculino",
			"cidade": "Sao Paulo",
			"estado_uf": "SP",
			"escolaridade": "Ensino Superior Completo"
		}
	],
	"success_url": "https://seu-site.com/checkout/sucesso",
	"failure_url": "https://seu-site.com/checkout/erro",
	"pending_url": "https://seu-site.com/checkout/pendente"
}

