@base = https://unbitten-crescent-hut.ngrok-free.dev/api/v1
@public = https://gileadebackend-production.up.railway.app/api/v1

### Pessoas - criar
POST {{base}}/pessoas
Content-Type: application/json

{
	"nome": "APRO",
	"tipo_usuario": "Usuario",
	"senha": "hash_da_senha",
	"cpf": "12345678909",
	"idade": 29,
	"celular": "+55 11 99999-0001",
	"igreja": "Igreja Central",
	"papel_igreja": "Membro",
	"estado_civil": "Solteiro(a)",
	"email": "apro@exemplo.com",
	"sexo": "Masculino",
	"cidade": "Sao Paulo",
	"estado_uf": "SP",
	"escolaridade": "Ensino Superior Completo"
}

###
POST {{public}}/pessoas
Content-Type: application/json

{
	"nome": "APRO",
	"tipo_usuario": "Usuario",
	"senha": "hash_da_senha",
	"cpf": "12345678909",
	"idade": 29,
	"celular": "+55 11 99999-0001",
	"igreja": "Igreja Central",
	"papel_igreja": "Membro",
	"estado_civil": "Solteiro(a)",
	"email": "apro@exemplo.com",
	"sexo": "Masculino",
	"cidade": "Sao Paulo",
	"estado_uf": "SP",
	"escolaridade": "Ensino Superior Completo"
}



### Pessoas - listar
GET {{base}}/pessoas?limit=50&offset=0

###
GET {{public}}/pessoas?limit=50&offset=0


### Pessoas - buscar por ID
GET {{base}}/pessoas/1

### Pessoas - atualizar
PUT {{base}}/pessoas/1
Content-Type: application/json

{
	"nome": "Maria Silva Souza",
	"email": "maria.souza@exemplo.com"
}

### Pessoas - remover
DELETE {{base}}/pessoas/1

### Tickets - criar
POST {{base}}/tickets
Content-Type: application/json

{
	"tipo": "Individual",
	"nome": "Ingresso Geral",
	"descricao": "Entrada padrao",
	"preco": "120.00",
	"quantidade_disponivel": 100,
	"data_evento": "2026-10-20"
}
###

POST {{public}}/tickets
Content-Type: application/json

{
	"tipo": "Individual",
	"nome": "Ingresso Geral",
	"descricao": "Entrada padrao",
	"preco": "200.00",
	"quantidade_disponivel": 100,
	"data_evento": "2026-10-20"
}

### Tickets - listar
GET {{base}}/tickets?limit=50&offset=0

###
GET {{public}}/tickets?limit=50&offset=0


### Tickets - buscar por ID
GET {{base}}/tickets/1

### Tickets - atualizar
PUT {{base}}/tickets/1
Content-Type: application/json

{
	"descricao": "Entrada padrao (lote 2)",
	"preco": "150.00"
}

### Tickets - remover
DELETE {{base}}/tickets/1

### Tickets-compra - criar vinculo
POST {{base}}/tickets-compra
Content-Type: application/json

{
	"usuario_id": 8,
	"ticket_id": 2,
	"quantidade": 1,
	"status": "Pendente"
}

### Tickets-compra - buscar por ID
GET {{base}}/tickets-compra/1

### Tickets-compra - listar por usuario
GET {{base}}/usuarios/8/tickets-compra?limit=50&offset=0

###
GET {{public}}/usuarios/1/tickets-compra?limit=50&offset=0

### Tickets-compra - atualizar status
PATCH {{base}}/tickets-compra/1/status
Content-Type: application/json

{
	"status": "Pago"
}

### Tickets-compra - remover
DELETE {{base}}/tickets-compra/1

### Pagamentos - checkout (gateway via service)
POST {{base}}/pagamentos/checkout
Content-Type: application/json

{
	"usuario_id": 8,
	"ticket_id": 2,
	"beneficiados": [
		{
			"nome": "Beneficiado 1",
			"cpf": "12345678909",
			"idade": 29,
			"celular": "+55 11 99999-0001",
			"igreja": "Igreja Central",
			"papel_igreja": "Membro",
			"estado_civil": "Solteiro(a)",
			"email": "beneficiado1@exemplo.com",
			"sexo": "Masculino",
			"cidade": "Sao Paulo",
			"estado_uf": "SP",
			"escolaridade": "Ensino Superior Completo"
		}
	],
	"quantidade": 1,
	"success_url": "https://seu-site.com/checkout/sucesso",
	"failure_url": "https://seu-site.com/checkout/erro",
	"pending_url": "https://seu-site.com/checkout/pendente"
}

###
